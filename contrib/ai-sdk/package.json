{
  "name": "@temporalio/ai-sdk",
  "version": "1.20.0",
  "description": "Temporal AI SDK integration package",
  "main": "lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "require": "./lib/index.js",
      "default": "./lib/index.js"
    },
    "./workflow": {
      "types": "./lib/workflow.d.ts",
      "import": "./lib/workflow.js",
      "require": "./lib/workflow.js",
      "default": "./lib/workflow.js"
    }
  },
  "typesVersions": {
    "*": {
      "workflow": [
        "./lib/workflow.d.ts"
      ]
    }
  },
  "keywords": [
    "temporal",
    "workflow",
    "ai",
    "ai-sdk",
    "llm",
    "embeddings"
  ],
  "author": "Temporal Technologies Inc. <sdk@temporal.io>",
  "license": "MIT",
  "scripts": {
    "build": "tsc --build",
    "test": "node ./scripts/run-tests.mjs"
  },
  "ava": {
    "timeout": "120s",
    "concurrency": 1,
    "workerThreads": false
  },
  "dependencies": {
    "@temporalio/activity": "workspace:*",
    "@temporalio/client": "workspace:*",
    "@temporalio/common": "workspace:*",
    "@temporalio/plugin": "workspace:*",
    "@temporalio/workflow": "workspace:*",
    "@temporalio/workflow-streams": "workspace:*",
    "@ungap/structured-clone": "^1.3.1",
    "headers-polyfill": "^4.0.3",
    "web-streams-polyfill": "^4.2.0"
  },
  "peerDependencies": {
    "@ai-sdk/mcp": "^2.0.0",
    "@ai-sdk/provider": "^4.0.0",
    "ai": "^7.0.0"
  },
  "devDependencies": {
    "@ai-sdk/mcp": "^2.0.0",
    "@ai-sdk/openai": "^4.0.0",
    "@ai-sdk/otel": "^1.0.0",
    "@ai-sdk/provider": "^4.0.0",
    "@modelcontextprotocol/sdk": "^1.25.2",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/core": "^1.25.1",
    "@opentelemetry/sdk-node": "^0.52.1",
    "@opentelemetry/semantic-conventions": "^1.25.1",
    "@temporalio/client": "workspace:*",
    "@temporalio/interceptors-opentelemetry": "workspace:*",
    "@temporalio/proto": "workspace:*",
    "@temporalio/test-helpers": "workspace:*",
    "@temporalio/testing": "workspace:*",
    "@temporalio/worker": "workspace:*",
    "@types/ungap__structured-clone": "^1.2.0",
    "ai": "^7.0.0",
    "ava": "^5.3.1",
    "zod": "^3.25.76"
  },
  "engines": {
    "node": ">= 22.12.0"
  },
  "bugs": {
    "url": "https://github.com/temporalio/sdk-typescript/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/temporalio/sdk-typescript.git",
    "directory": "contrib/ai-sdk"
  },
  "homepage": "https://github.com/temporalio/sdk-typescript/tree/main/contrib/ai-sdk",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "lib",
    "!src/__tests__",
    "!lib/__tests__"
  ]
}
