{
  "name": "@temporalio/openai-agents",
  "version": "1.19.0",
  "description": "Temporal OpenAI Agents SDK integration package",
  "main": "lib/index.js",
  "types": "./lib/index.d.ts",
  "typesVersions": {
    "*": {
      "workflow": [
        "./lib/workflow.d.ts"
      ],
      "workflow-interceptor": [
        "./lib/workflow/trace-interceptor.d.ts"
      ],
      "otel": [
        "./lib/otel.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "tsc --build",
    "build:watch": "tsc --build --watch",
    "test": "ava",
    "test:watch": "ava --watch"
  },
  "ava": {
    "files": [
      "./lib/__tests__/**/*.test.js",
      "./lib/__tests__/test-*.js"
    ],
    "timeout": "120s",
    "concurrency": 1,
    "workerThreads": false
  },
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "require": "./lib/index.js",
      "default": "./lib/index.js"
    },
    "./workflow": {
      "types": "./lib/workflow.d.ts",
      "import": "./lib/workflow.js",
      "require": "./lib/workflow.js",
      "default": "./lib/workflow.js"
    },
    "./workflow-interceptor": {
      "types": "./lib/workflow/trace-interceptor.d.ts",
      "import": "./lib/workflow/trace-interceptor.js",
      "require": "./lib/workflow/trace-interceptor.js",
      "default": "./lib/workflow/trace-interceptor.js"
    },
    "./otel": {
      "types": "./lib/otel.d.ts",
      "import": "./lib/otel.js",
      "require": "./lib/otel.js",
      "default": "./lib/otel.js"
    }
  },
  "keywords": [
    "temporal",
    "workflow",
    "ai",
    "openai",
    "agents"
  ],
  "author": "Temporal Technologies Inc. <sdk@temporal.io>",
  "license": "MIT",
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@temporalio/activity": "workspace:*",
    "@temporalio/common": "workspace:*",
    "@temporalio/plugin": "workspace:*",
    "@temporalio/worker": "workspace:*",
    "@temporalio/workflow": "workspace:*",
    "@temporalio/workflow-streams": "workspace:*",
    "@ungap/structured-clone": "^1.3.1",
    "headers-polyfill": "^4.0.3",
    "web-streams-polyfill": "^4.2.0"
  },
  "peerDependencies": {
    "@openai/agents-core": "~0.11.6",
    "@openai/agents-openai": "~0.11.6",
    "@opentelemetry/sdk-trace-base": "^1.25.1",
    "openai": "^6.35.0"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/sdk-trace-base": {
      "optional": true
    }
  },
  "devDependencies": {
    "@openai/agents-core": "~0.11.6",
    "@openai/agents-openai": "~0.11.6",
    "@opentelemetry/core": "^1.25.1",
    "@opentelemetry/sdk-node": "^0.52.1",
    "@opentelemetry/sdk-trace-base": "^1.25.1",
    "@opentelemetry/semantic-conventions": "^1.25.1",
    "@temporalio/client": "workspace:*",
    "@temporalio/proto": "workspace:*",
    "@temporalio/test-helpers": "workspace:*",
    "@temporalio/testing": "workspace:*",
    "ava": "^5.3.1",
    "nexus-rpc": "^0.0.2",
    "openai": "^6.35.0"
  },
  "engines": {
    "node": ">= 20.3.0"
  },
  "bugs": {
    "url": "https://github.com/temporalio/sdk-typescript/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/temporalio/sdk-typescript.git",
    "directory": "contrib/openai-agents"
  },
  "homepage": "https://github.com/temporalio/sdk-typescript/tree/main/contrib/openai-agents",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "lib",
    "!src/__tests__",
    "!lib/__tests__"
  ]
}
