{
  "name": "@temporalio/proto",
  "version": "1.21.0",
  "description": "Temporal.io SDK compiled protobuf definitions",
  "main": "protos/index.js",
  "types": "protos/index.d.ts",
  "files": [
    "protos/",
    "src/",
    "lib/"
  ],
  "scripts": {
    "build": "pnpm run gen && pnpm run build:ts",
    "build:ts": "tsc --build",
    "gen": "pnpm run gen:protos && pnpm run gen:payload-visitor",
    "gen:protos": "tsx ./scripts/compile-proto.ts",
    "gen:payload-visitor": "tsx ./scripts/gen-payload-visitor.ts"
  },
  "keywords": [
    "temporal",
    "workflow",
    "isolate"
  ],
  "author": "Temporal Technologies Inc. <sdk@temporal.io>",
  "license": "MIT",
  "dependencies": {
    "long": "^5.2.3",
    "protobufjs": "^7.6.5"
  },
  "devDependencies": {
    "glob": "^10.3.10",
    "protobufjs-cli": "^1.2.2"
  },
  "bugs": {
    "url": "https://github.com/temporalio/sdk-typescript/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/temporalio/sdk-typescript.git",
    "directory": "packages/proto"
  },
  "homepage": "https://github.com/temporalio/sdk-typescript/tree/main/packages/proto",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">= 20.3.0"
  }
}
